# ─── LeafLore Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-secret

# PostgreSQL connection string (from Supabase / Neon / Railway / Render)
# Local SQLite fallback is used if this is not set.
DATABASE_URL=postgresql://user:password@host:5432/leaflore

# ── Optional ──────────────────────────────────────────────────────────────────
# Flask environment: "production" | "development" | "testing"
FLASK_ENV=production

# Google Books API key (optional — search still works without it at low volume)
GOOGLE_BOOKS_API_KEY=

# Sentry DSN for error monitoring (free at sentry.io)
SENTRY_DSN=

# ── Local development only ────────────────────────────────────────────────────
# Set FLASK_DEBUG=1 only locally, never in production
FLASK_DEBUG=0
